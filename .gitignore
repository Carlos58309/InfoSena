# =============================================
# .gitignore para InfoSENA (Django + MySQL + Redis)
# =============================================

# ---- Entorno Virtual de Python ----
venv/
env/
.venv/
ENV/
SENA/
Lib/
Scripts/
Include/
pyvenv.cfg

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ---- Variables de entorno (SECRETOS) ----
.env
.env.local
.env.production
.env.*.local

# ---- Django ----
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
staticfiles/

# ---- Media (archivos subidos por usuarios) ----
media/chat_archivos/
media/grupos/
media/perfiles/
media/perfils/
media/publicaciones/

# ---- MySQL ----
*.sql
*.sql.gz

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Sistema Operativo ----
*.tmp
*.bak
*.orig